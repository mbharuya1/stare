# Anthropic API key for Claude (required for /query generation + classification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CourtListener API token (legacy; not used by current pipeline)
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# Password for the analytics dashboard at /Analytics
STARE_ADMIN_PASSWORD=change_me_in_production

# LangSmith tracing — leave LANGSMITH_API_KEY blank to disable
LANGSMITH_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=stare-v2

# Reranker toggle (true|false) — set false to A/B test plain vector retrieval
USE_RERANKER=true
