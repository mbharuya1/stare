# Backend container env vars. Copy to backend/.env on the EC2 instance:
#     cp backend/.env.example backend/.env
# and fill in real values. backend/.env is gitignored.

# Required: Claude API key for /query generation + classification.
ANTHROPIC_API_KEY=

# Optional: CourtListener bulk-download token (legacy; not used by the
# current pipeline but read by config.py for backwards compatibility).
COURTLISTENER_API_TOKEN=

# Optional: LangSmith tracing. Leave blank to run without tracing.
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=stare-v2

# Retrieval knobs. Defaults match production.
USE_RERANKER=true
RERANK_TOP_K=5
VECTOR_TOP_K=20
LOW_CONFIDENCE_THRESHOLD=0.3

# Model overrides (verified IDs as of 2026-05).
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
GENERATOR_MODEL=claude-sonnet-4-6
