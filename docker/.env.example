# ─────────────────────────────────────────────────────────────────────
# Stare compose-level env vars. These are substituted into
# docker-compose.yml via the --env-file flag. Backend secrets
# (ANTHROPIC_API_KEY etc.) live in backend/.env, NOT here.
#
# Copy to docker/.env on the EC2 instance:
#     cp docker/.env.example docker/.env
# ─────────────────────────────────────────────────────────────────────

# Public hostname for the deployment. Leave blank to fall back to
# plain HTTP on :80 (useful during the first few minutes of a new
# deployment, before DNS propagates). When set, Caddy automatically
# issues a Let's Encrypt cert on first request.
DOMAIN=

# Email Let's Encrypt uses for renewal notices.
ACME_EMAIL=admin@example.com

# URL of the Next.js landing page (used by the "Back to landing" link
# in the Streamlit header).
LANDING_URL=https://stare.legal
