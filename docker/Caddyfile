# Stare reverse proxy.
#
# A single site block keyed on {$DOMAIN}. Caddy auto-detects what to do:
#   - If DOMAIN is a hostname (e.g. stare.legal), Caddy serves it over
#     HTTPS with a Let's Encrypt cert issued on first request.
#   - If DOMAIN starts with ":" (e.g. ":80"), Caddy serves plain HTTP
#     on that port. docker-compose substitutes ":80" as the default
#     when the operator has not set DOMAIN, so the proxy is usable
#     immediately, before DNS or a domain exists.
#
# Routing:
#   /api/*    → backend  (FastAPI)   — the /api prefix is stripped.
#   /healthz  → backend /health      — convenience alias.
#   *         → frontend (Streamlit) — websocket-friendly proxy.

{
    email {$ACME_EMAIL}
    # Uncomment for staging certs while testing:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
    encode zstd gzip

    # Backend API: strip /api before forwarding to FastAPI.
    handle_path /api/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Convenience alias for the backend health check.
    handle /healthz {
        reverse_proxy backend:8000
        rewrite * /health
    }

    # Everything else: Streamlit. The /_stcore/* websocket needs the
    # full path preserved (no prefix strip), which is what handle does.
    handle {
        reverse_proxy frontend-app:8501 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Security headers (modest defaults; Streamlit needs inline scripts).
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "camera=(), microphone=(), geolocation=()"
        -Server
    }

    log {
        output stdout
        format console
        level  INFO
    }
}
