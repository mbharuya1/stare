# Stare reverse proxy.
#
# Two virtual hosts:
#   1. {$DOMAIN} on 443  — production HTTPS, Let's Encrypt cert auto-issued
#      by Caddy on first request.
#   2. :80              — fallback for IP-based or pre-DNS access, plain HTTP.
#
# Routing:
#   /api/*  → backend  (FastAPI)   — the /api prefix is stripped.
#   *       → frontend (Streamlit) — websocket-friendly proxy for live reloads.
#
# Use Caddy environment-variable substitution. DOMAIN is read from
# docker-compose's environment block; if it is unset, the {$DOMAIN}
# block becomes the literal hostname "" which Caddy ignores, so only
# the :80 fallback site is served.

{
    email {$ACME_EMAIL}
    # Uncomment for staging certs while testing:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ───────────────────────── 1. Production HTTPS ─────────────────────────
{$DOMAIN} {
    encode zstd gzip

    # Backend API: strip /api before forwarding to FastAPI.
    handle_path /api/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Streamlit health endpoint (also reachable through the catch-all).
    handle /healthz {
        reverse_proxy backend:8000
        rewrite * /health
    }

    # Everything else: Streamlit. The /_stcore/* websocket needs the
    # full path preserved (no prefix strip), which is what handle does.
    handle {
        reverse_proxy frontend-app:8501 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Security headers (modest defaults; Streamlit needs inline scripts).
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "camera=(), microphone=(), geolocation=()"
        -Server
    }

    log {
        output stdout
        format console
        level  INFO
    }
}

# ───────────────────────── 2. Plain HTTP fallback ──────────────────────
# Useful for the first few minutes after launch when DNS has not yet
# propagated. Same routing as the HTTPS host above.
:80 {
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    handle /healthz {
        reverse_proxy backend:8000
        rewrite * /health
    }

    handle {
        reverse_proxy frontend-app:8501
    }

    log {
        output stdout
        format console
        level  INFO
    }
}
